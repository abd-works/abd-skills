{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": ".cursor/scripts/session-setup.sh",
        "powershell": ".cursor/scripts/session-setup.ps1",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": ".cursor/scripts/detect-correction.sh",
        "powershell": ".cursor/scripts/detect-correction.ps1",
        "cwd": ".",
        "timeoutSec": 5
      }
    ]
  }
}
