{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./scripts/session-setup.sh",
        "powershell": "./scripts/session-setup.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./scripts/detect-correction.sh",
        "powershell": "./scripts/detect-correction.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 5
      }
    ]
  }
}
