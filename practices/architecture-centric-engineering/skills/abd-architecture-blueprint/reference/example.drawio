    <diagram id="platform-architecture" name="Platform Architecture">
        <mxGraphModel dx="379" dy="343" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="960" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
