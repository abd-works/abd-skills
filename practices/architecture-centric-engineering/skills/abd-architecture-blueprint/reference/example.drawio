                <mxCell id="storeLocator" value="&lt;b&gt;Store Locator API&lt;/b&gt;&#10;(Third-Party Integration)&#10;&#10;External geolocation service.&#10;Called read-only by API Server&#10;for store proximity queries.&#10;&#10;Protocol: HTTPS / REST + JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" parent="1" vertex="1">
