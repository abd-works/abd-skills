                    <mxGeometry x="60" y="590" width="700" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="mongodb" value="&lt;b&gt;MongoDB Atlas&lt;/b&gt;&lt;br&gt;(Data Store — MongoDB 7)&lt;br&gt;&lt;br&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=20;fillColor=#ffffff;strokeColor=#b85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" parent="1" vertex="1">
