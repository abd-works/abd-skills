                <mxCell id="title" value="PawPlace Pet Store — Platform Architecture" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="1320" height="32" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Runtime components, technologies, and the connections between them. Deployment topology (environments, infra nodes, OS images) lives in deployment-architecture.drawio." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="40" y="55" width="1320" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="browserLayer" value="Browser / Client" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="60" y="90" width="700" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="spa" value="&lt;b&gt;PawPlace React SPA&lt;/b&gt;&lt;br&gt;(Client Application)&lt;br&gt;&lt;br&gt;React 18 · React Router 6&lt;br&gt;TanStack Query 5 · Vite 5&lt;br&gt;TypeScript 5&lt;br&gt;Customer + employee UI." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="100" y="125" width="300" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="cdnBox" value="&lt;b&gt;Static Asset Host / CDN&lt;/b&gt;&#10;(CDN / Edge)&#10;&#10;Serves compiled SPA bundle&#10;(HTML, JS, CSS) from edge.&#10;Reduces origin load for&#10;SPA requests." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f0fa;strokeColor=#6c8ebf;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="430" y="125" width="290" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="serverLayer" value="Server Layer — Node.js 20" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;verticalAlign=top;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="60" y="310" width="700" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="apiServer" value="&lt;b&gt;PawPlace API Server&lt;/b&gt;&#10;(Backend Service)&#10;&#10;Node.js 20 · Express 4 · Zod 3&#10;TypeScript 5&#10;&#10;Composition root; mounts all&#10;domain module routers.&#10;Handles all /api/* routes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="100" y="350" width="310" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="syncWorker" value="&lt;b&gt;Inventory B2B Sync Worker&lt;/b&gt;&#10;(Background Worker)&#10;&#10;Node.js 20 · TypeScript 5 · Zod 3&#10;&#10;Receives inbound supplier&#10;inventory webhooks; sends&#10;outbound fulfilment confirmations.&#10;Separate process from API Server." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="440" y="350" width="290" height="160" as="geometry"/>
                </mxCell>
