{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@pawplace-mini/cart-shared": ["./packages/cart/shared/src/index.ts"],
      "@pawplace-mini/cart-server": ["./packages/cart/server/index.ts"],
      "@pawplace-mini/cart-client": ["./packages/cart/client/index.ts"],
      "@pawplace-mini/app-server": ["./packages/app-server/index.ts"],
      "@pawplace-mini/catalog-client": ["./packages/catalog/client/index.ts"],
      "@pawplace-mini/inventory-client": ["./packages/inventory/client/index.ts"],
      "@pawplace-mini/store-shared": ["./packages/store/shared/index.ts"],
      "@pawplace-mini/store-server": ["./packages/store/server/index.ts"],
      "@pawplace-mini/store-client": ["./packages/store/client/index.ts"],
      "@pawplace-mini/store-client/*": ["./packages/store/client/*"],
      "@pawplace-mini/checkout-client": ["./packages/checkout/client/index.ts"],
      "@pawplace-mini/checkout-shared": ["./packages/checkout/shared/src/index.ts"],
      "@pawplace-mini/fulfillment-client": ["./packages/fulfillment/client/index.ts"],
      "@pawplace-mini/fulfillment-shared": ["./packages/fulfillment/shared/src/index.ts"],
      "@pawplace-mini/fulfillment-server": ["./packages/fulfillment/server/index.ts"]
    }
  },
  "include": ["packages/**/*", "tests/**/*"]
}
