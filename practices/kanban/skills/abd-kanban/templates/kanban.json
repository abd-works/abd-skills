{
  "schema": "abd-kanban-board/v1",
  "definitions": {
    "default-new-build": {
      "label": "Default new build",
      "strategy": {
        "scatter_rules": {
          "all_to_increment": "one ticket per increment from thin-slicing; scatter all",
          "increment_to_sprint": "group 3-4 stories per sprint; scatter next 1-2 increments JIT"
        },
        "checkpoint_policy": "per_skill",
        "autonomy": "moderate"
      },
      "team": {
        "product-owner": 1,
        "business-expert": 1,
        "ux-designer": 1,
        "engineer": 1
      },
      "stages": [
        {
          "name": "shaping",
          "scope": "all",
          "stage_work_required": [
            { "skill": "abd-domain-glossary", "role": "business-expert" },
            { "skill": "abd-story-mapping", "role": "product-owner" },
            { "skill": "abd-impact-mapping", "role": "product-owner" },
            { "skill": "abd-architecture-outline", "role": "engineer" }
          ]
        },
        {
          "name": "discovery",
          "scope": "all",
          "stage_work_required": [
            { "skill": "abd-story-mapping", "role": "product-owner" },
            { "skill": "abd-domain-language", "role": "business-expert" },
            { "skill": "abd-information-architecture", "role": "ux-designer" },
            { "skill": "abd-architecture-blueprint", "role": "engineer" }
          ]
        },
        {
          "name": "exploration",
          "scope": "increment",
          "stage_work_required": [
            { "skill": "abd-domain-model", "role": "business-expert" },
            { "skill": "abd-story-acceptance-criteria", "role": "product-owner" },
            { "skill": "abd-ux-mockup", "role": "ux-designer" },
            { "skill": "abd-architecture-specification", "role": "engineer", "run_when": "increment_needs_undocumented_mechanisms", "mode": "document" }
          ]
        },
        {
          "name": "specification",
          "scope": "sprint",
          "stage_work_required": [
            { "skill": "abd-domain-specification", "role": "business-expert" },
            { "skill": "abd-story-specification", "role": "product-owner" },
            { "skill": "abd-ux-specification", "role": "ux-designer" },
            { "skill": "abd-architecture-specification", "role": "engineer", "mode": "template" }
          ]
        },
        {
          "name": "engineering",
          "scope": "sprint",
          "stage_work_required": [
            { "skill": "abd-domain-code", "role": "business-expert" },
            { "skill": "abd-story-acceptance-test", "role": "product-owner" },
            { "skill": "abd-clean-code", "role": "engineer" },
            { "skill": "abd-architecture-code", "role": "engineer", "run_when": "named_architecture_spec_assigned" }
          ]
        }
      ]
    },
