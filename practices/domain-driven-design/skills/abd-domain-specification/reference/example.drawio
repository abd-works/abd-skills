                </mxCell>
                <mxCell id="3" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;TimeSlot&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:10px;&quot;&gt;+ startTime: DateTime&lt;br/&gt;+ endTime: DateTime&lt;br/&gt;+ duration: Duration&lt;br/&gt;+ availableDateAndTimeWindow: Store&lt;br/&gt;+ slotBookingStatus: String&lt;br/&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:10px;&quot;&gt;+ holdForAppointmentRequest(request: AppointmentRequest): void&lt;br/&gt;+ releaseOnHoldExpiry(): void&lt;br/&gt;+ consumeOnBookingConfirmation(appointment: Appointment): void&lt;br/&gt;+ releaseOnAppointmentCancellation(): void&lt;br/&gt;+ isAvailable(): Boolean&lt;br/&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:9px;color:#666;&quot;&gt;&lt;i&gt;scoped to a specific store&amp;#x27;s operating hours&lt;/i&gt;&lt;br/&gt;&lt;i&gt;available → held when customer selects slot; held → booked on appointment confir...&lt;/i&gt;&lt;br/&gt;&lt;i&gt;slot transitions to held when customer selects it; held slot is not visible to o...&lt;/i&gt;&lt;br/&gt;&lt;i&gt;slot returns to available if the appointment request is not confirmed within the...&lt;/i&gt;&lt;br/&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;whiteSpace=wrap;" vertex="1" parent="1">
