                </mxCell>
                <mxCell id="4" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;AppointmentRequest&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:10px;&quot;&gt;+ requestingCustomerAccount: CustomerAccount&lt;br/&gt;+ requestedPet: Pet&lt;br/&gt;+ selectedTimeSlot: TimeSlot&lt;br/&gt;+ slotHoldDuration: Integer&lt;br/&gt;+ optionalVisitNote: String&lt;br/&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:10px;&quot;&gt;+ confirmToCreateAppointment(): Appointment&lt;br/&gt;+ releaseSlotOnHoldExpiry(): void&lt;br/&gt;+ blockOnUnauthenticatedRequest(): void&lt;br/&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:9px;color:#666;&quot;&gt;&lt;i&gt;must be submitted by a verified customer account; guest sessions cannot initiate...&lt;/i&gt;&lt;br/&gt;&lt;i&gt;must reference exactly one pet with status available&lt;/i&gt;&lt;br/&gt;&lt;i&gt;slot transitions to held status on selection; held slot not shown to other custo...&lt;/i&gt;&lt;br/&gt;&lt;i&gt;hold expires if booking is not confirmed within hold duration&lt;/i&gt;&lt;br/&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;whiteSpace=wrap;" vertex="1" parent="1">
                    <mxGeometry x="133" y="1908" width="260" height="246" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;AppointmentCancellation&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:10px;&quot;&gt;+ cancelledAppointment: Appointment&lt;br/&gt;+ cancellationDate: Date&lt;br/&gt;+ cancellationReason: String&lt;br/&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:10px;&quot;&gt;+ releaseBookedTimeSlot(): void&lt;br/&gt;+ recordInAppointmentHistory(): void&lt;br/&gt;+ triggerRebookingOffer(): void&lt;br/&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:9px;color:#666;&quot;&gt;&lt;i&gt;must reference the appointment being withdrawn&lt;/i&gt;&lt;br/&gt;&lt;i&gt;releases the time slot back to available so another customer may book it&lt;/i&gt;&lt;br/&gt;&lt;i&gt;cancellation recorded in the customer account&amp;#x27;s appointment history&lt;/i&gt;&lt;br/&gt;&lt;i&gt;offer surfaced when customer cancels after receiving pet-adopted notification&lt;/i&gt;&lt;br/&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;whiteSpace=wrap;" vertex="1" parent="1">
