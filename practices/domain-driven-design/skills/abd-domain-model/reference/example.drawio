            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;Payment&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:10px;&quot;&gt;+ payment reference&lt;br/&gt;+ payment amount&lt;br/&gt;+ currency&lt;br/&gt;+ payment date&lt;br/&gt;+ payment status&lt;br/&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:10px;&quot;&gt;+ associated order : Order&lt;br/&gt;+ payment method used : Payment Vendor, Saved Payment Method, Payment Method Selector&lt;br/&gt;+ processing vendor : Payment Vendor&lt;br/&gt;+ vendor transaction reference : Vendor Transaction Reference&lt;br/&gt;+ process through selected vendor : Payment Method Selector, StripeWave, PayNova, VaultPay, Saved Payment Method&lt;br/&gt;+ reconcile via webhook callback : Webhook Callback&lt;br/&gt;+ initiate payment retry on transient error : Payment Retry, Transient Error, Payment Vendor&lt;br/&gt;+ surface hard decline immediately : Hard Decline, Payment Method Selector&lt;br/&gt;+ continue payment retry in background : Payment Retry, Order, Confirmation Email&lt;br/&gt;+ route refund through original vendor : Refund, Payment Vendor, Refund Status&lt;br/&gt;+ initiate refund retry on vendor failure : Refund Retry, Refund, Payment Vendor&lt;br/&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;whiteSpace=wrap;" vertex="1" parent="1">
