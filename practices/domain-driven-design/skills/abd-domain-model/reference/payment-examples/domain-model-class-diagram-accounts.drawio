                <mxCell id="200" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;UserProfile&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:10px;&quot;&gt;name: PersonName&lt;br/&gt;email: EmailAddress&lt;br/&gt;contactInfo: ContactInfo&lt;br/&gt;enterpriseGroup: EnterpriseGroup&lt;br/&gt;entitlements: Entitlement&lt;br/&gt;accessStatus: AccessStatus&lt;br/&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:10px;&quot;&gt;enable(): UserProfile&lt;br/&gt;disable(): UserProfile&lt;br/&gt;assignEntitlement(Entitlement): UserProfile&lt;br/&gt;revokeEntitlement(Entitlement): UserProfile&lt;br/&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;font-size:9px;color:#666;&quot;&gt;&lt;i&gt;belongs to exactly one enterprise group&lt;/i&gt;&lt;br/&gt;&lt;i&gt;user can only hold a profile in the same group&lt;/i&gt;&lt;br/&gt;&lt;i&gt;profiles built per enterprise group, not shared&lt;/i&gt;&lt;br/&gt;&lt;i&gt;only user with assign-entitlement can assign/revoke&lt;/i&gt;&lt;br/&gt;&lt;i&gt;disabled profile prevents sign-in&lt;/i&gt;&lt;br/&gt;&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;whiteSpace=wrap;" parent="1" vertex="1">
