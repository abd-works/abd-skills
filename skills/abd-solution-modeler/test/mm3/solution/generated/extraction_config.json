{
  "tf_weights": {
    "heading": 5,
    "table_header": 4,
    "definition_sentence": 3,
    "capitalized_noun": 2,
    "regular": 1,
    "bold_term": 3,
    "list_item_lead": 2
  },
  "definition_patterns": [
    "^([A-Z][a-zA-Z ]+) (is|represents|refers to|describes|means)\\s+",
    "\\b([A-Z][A-Za-z0-9]*(?:\\s+[A-Z][A-Za-z0-9]*){0,3})\\s+(?:is|represents|refers to|describes|means)\\s+",
    "([A-Z][a-zA-Z ]+) (?:is|are) (?:the|a|an)\\s+"
  ],
  "dependency_verbs": [
    "has", "have", "contains", "includes", "uses", "requires",
    "applies", "targets", "modifies", "affects", "grants", "inflicts",
    "resists", "rolls", "checks", "attacks", "defends"
  ],
  "np_mining": {
    "min_frequency": 2,
    "max_words": 4,
    "prioritize_compound": true
  },
  "cooccurrence": {
    "window_size": "chunk",
    "min_count": 2,
    "max_edges": 300
  },
  "table_mining": {
    "header_pattern": "^\\s*\\|([^|]+)\\|",
    "concept_columns": ["header", "row_label"],
    "ignore_patterns": ["page", "chapter", "table of contents", "RANK", "MASS", "TIME", "DISTANCE", "VOLUME"]
  },
  "enumeration_patterns": [
    "types of ([A-Z][a-zA-Z ]+) include",
    "([A-Z][a-zA-Z ]+) may be",
    "([A-Z][a-zA-Z ]+) categories are",
    "([A-Z][a-zA-Z ]+) can be one of",
    "forms of ([A-Z][a-zA-Z ]+)",
    "The abilities are: ([A-Z][a-zA-Z ,]+)",
    "effects? (?:include|are): ([A-Z][a-zA-Z ,]+)",
    "([A-Z][a-zA-Z ]+) (?:include|are):"
  ],
  "contrast_patterns": [
    "unlike ([A-Z][a-zA-Z ]+),\\s+([A-Z][a-zA-Z ]+)",
    "([A-Z][a-zA-Z ]+) differs from ([A-Z][a-zA-Z ]+)",
    "while ([A-Z][a-zA-Z ]+).*,\\s+([A-Z][a-zA-Z ]+)",
    "in contrast to ([A-Z][a-zA-Z ]+)",
    "as opposed to ([A-Z][a-zA-Z ]+)"
  ],
  "actor_detection": {
    "actor_verbs": [
      "rolls", "selects", "chooses", "determines", "decides",
      "assigns", "activates", "initiates", "creates", "submits",
      "attacks", "defends", "checks", "resists"
    ],
    "known_actors": ["character", "hero", "player", "Gamemaster", "GM", "villain", "NPC"],
    "actor_noun_pattern": "(character|hero|player|gamemaster|gm|villain|user|system|admin|manager|operator)"
  },
  "topic_modeling": {
    "n_clusters": 10,
    "min_cluster_size": 3,
    "stop_words": [
      "the", "a", "an", "is", "are", "was", "were", "be", "been", "being",
      "to", "of", "and", "in", "for", "on", "with", "at", "by", "from",
      "or", "but", "not", "this", "that", "it", "its", "you", "your"
    ],
    "domain_stop_words": ["check", "checks", "rank", "ranks", "effect", "action", "round", "rounds"]
  },
  "centrality": {
    "metric": "degree",
    "top_n": 25,
    "threshold": 0.02
  },
  "verb_interaction": {
    "min_verb_frequency": 3,
    "verb_patterns": [],
    "exclude_verbs": [
      "is", "are", "was", "were", "has", "have", "had",
      "can", "may", "should", "would", "could", "will", "shall",
      "do", "does", "did", "been", "being", "be"
    ],
    "prioritize_domain_verbs": true
  },
  "noise_filters": [
    "table of contents", "appendix", "index", "license",
    "copyright", "acknowledgments", "foreword", "preface",
    "Next-to-Instant Heroes", "Using the Quickstart",
    "Green Ronin Publishing", "Open Game License"
  ]
}
